extends layout
block content
    .listing-detail
        if listing.imageURL
            img(src=listing.imageURL alt=listing.title)
        .detail-body
            h1 #{listing.title}
            .detail-meta
                span.category-badge #{listing.category}
                |  Posted by 
                a(href='/users/' + listing.userID) #{listing.username}
                |  — #{new Date(listing.createdAt).toLocaleDateString()}
                if listing.location
                    |  — 📍 #{listing.location}
            
            if ratingData && ratingData.totalReviews > 0
                .rating-summary
                    span.rating-stars #{parseFloat(ratingData.avgRating).toFixed(1)} ★
                    span  (#{ratingData.totalReviews} review#{ratingData.totalReviews > 1 ? 's' : ''})

            if query && query.messageSent
                .alert.alert-success Your message has been sent!
            if query && query.reported
                .alert.alert-success Thank you. Your report has been submitted.
            if query && query.alreadyReported
                .alert.alert-warning You have already reported this listing.
            if query && query.reviewed
                .alert.alert-success Your review has been submitted!
            if query && query.alreadyReviewed
                .alert.alert-warning You have already reviewed this listing.

            p.detail-description #{listing.description}

            //- OpenStreetMap with Leaflet
            if listing.latitude && listing.longitude
                h3 Pickup Location
                link(rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css')
                #map(style='width: 100%; height: 300px; border-radius: 10px; margin: 15px 0;')
                script(src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js')
                script.
                    var map = L.map('map').setView([#{listing.latitude}, #{listing.longitude}], 14);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '© OpenStreetMap contributors'
                    }).addTo(map);
                    L.marker([#{listing.latitude}, #{listing.longitude}]).addTo(map)
                        .bindPopup('#{listing.title}').openPopup();
                        

            if session && session.loggedIn && session.uid != listing.userID
                h3 Contact Owner
                form(action='/messages/send' method='POST')
                    input(type='hidden' name='receiverID' value=listing.userID)
                    input(type='hidden' name='listingID' value=listing.id)
                    .form-group
                        textarea(name='content' placeholder='Write your message...' rows='3' required)
                    button.btn.btn-green(type='submit') Send Message

                h3 Leave a Review
                form(action='/listings/' + listing.id + '/review' method='POST')
                    .form-group
                        label Rating
                        select(name='rating' required)
                            option(value='') -- Select rating --
                            option(value='5') ★★★★★ (5)
                            option(value='4') ★★★★ (4)
                            option(value='3') ★★★ (3)
                            option(value='2') ★★ (2)
                            option(value='1') ★ (1)
                    .form-group
                        textarea(name='comment' placeholder='Write a review (optional)...' rows='2')
                    button.btn.btn-green(type='submit') Submit Review

                h3 Report Listing
                form(action='/listings/' + listing.id + '/report' method='POST')
                    .form-group
                        select(name='reason' required)
                            option(value='') -- Select a reason --
                            option(value='Inappropriate content') Inappropriate content
                            option(value='Spam or scam') Spam or scam
                            option(value='Offensive language') Offensive language
                            option(value='Incorrect category') Incorrect category
                            option(value='Other') Other
                    button.btn.btn-red.btn-small(type='submit') Report

            if session && session.loggedIn && session.uid == listing.userID
                div(style='margin-top: 15px;')
                    a.btn.btn-outline-green(href='/listings/' + listing.id + '/edit') Edit this listing

    //- Reviews section
    if reviews && reviews.length > 0
        h2.page-title(style='margin-top: 30px;') Reviews
        each review in reviews
            .message-box
                .msg-header
                    span
                        strong #{review.username}
                        |  — #{'★'.repeat(review.rating)}#{'☆'.repeat(5 - review.rating)}
                    span #{new Date(review.createdAt).toLocaleDateString()}
                if review.comment
                    .msg-content #{review.comment}

    //- Similar listings
    if similar && similar.length > 0
        h2.page-title(style='margin-top: 30px;') Similar Listings
        .cards-grid
            each item in similar
                .card
                    if item.imageURL
                        img(src=item.imageURL alt=item.title)
                    else
                        .no-image No Image
                    .card-body
                        h3
                            a(href='/listings/' + item.listingID) #{item.title}
                        span.category-badge #{item.category}
                        if item.avgRating
                            span.rating-badge #{parseFloat(item.avgRating).toFixed(1)} ★

    br
    a(href='/listings') ← Back to all listings