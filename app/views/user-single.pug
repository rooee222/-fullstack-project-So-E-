extends layout
block content
    .profile-card
        if user.profilePic
            img(src=user.profilePic style='width: 100px; height: 100px; border-radius: 50%; object-fit: cover; margin-bottom: 15px;')
        h1 #{user.username}'s Profile
        .profile-info
            p Email: #{user.email}
            if user.location
                p Location: #{user.location}
            p Member since: #{new Date(user.createdAt).toLocaleDateString()}
            p Points: #{user.points || 0} pts
            if userRating && userRating.totalReviews > 0
                p Seller Rating: #{parseFloat(userRating.avgRating).toFixed(1)} ★ (#{userRating.totalReviews} review#{userRating.totalReviews > 1 ? 's' : ''})
        if session && session.loggedIn && session.uid == user.userID
            a.btn.btn-outline-green(href='/profile/edit' style='margin-top: 10px;') Edit Profile

    h2.page-title Listings by #{user.username}
    if listings.length === 0
        p This user has no listings yet.
    else
        .cards-grid
            each item in listings
                .card
                    if item.imageURL
                        img(src=item.imageURL alt=item.title)
                    else
                        .no-image No Image
                    .card-body
                        h3
                            a(href='/listings/' + item.listingID) #{item.title}
                        span.category-badge #{item.category}
                        .card-meta #{new Date(item.createdAt).toLocaleDateString()}