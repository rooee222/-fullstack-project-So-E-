extends layout
block content
    h1.page-title Post a New Listing

    .form-container
        form(action='/listings/new' method='POST' enctype='multipart/form-data' id='listingForm')
            .form-group
                label Title
                input(type='text' name='title' placeholder='What are you sharing?' required)
            .form-group
                label Description
                textarea(name='description' placeholder='Describe the item...' required)
            .form-group
                label Category
                select(name='category')
                    option(value='Books') Books
                    option(value='Tools') Tools
                    option(value='Clothes') Clothes
                    option(value='Kitchen') Kitchen
                    option(value='Accessories') Accessories
                    option(value='Shoes') Shoes
                    option(value='Bags') Bags
                    option(value='Other') Other
            .form-group
                label Image
                input(type='file' name='image' accept='image/*')
            .form-group
                label Pickup Location (postcode or address)
                input(type='text' name='location' id='locationInput' placeholder='e.g. SW15 5PU or Roehampton Lane, London')
                input(type='hidden' name='latitude' id='latInput')
                input(type='hidden' name='longitude' id='lngInput')
                #locationPreview(style='margin-top: 10px; color: #777; font-size: 0.9em;')
                button.btn.btn-grey.btn-small(type='button' onclick='findLocation()' style='margin-top: 8px;') Find on Map
                link(rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css')
                #mapPreview(style='width: 100%; height: 250px; border-radius: 10px; margin-top: 10px; display: none;')
            button.btn.btn-green(type='submit') Post Listing
        br
        a(href='/listings') Cancel

    script(src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js')
    script.
        var previewMap = null;
        var previewMarker = null;
        function findLocation() {
            var address = document.getElementById('locationInput').value;
            if (!address) {
                document.getElementById('locationPreview').innerText = 'Please enter a postcode or address';
                return;
            }
            document.getElementById('locationPreview').innerText = 'Searching...';
            fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(address))
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.length > 0) {
                        var lat = parseFloat(data[0].lat);
                        var lng = parseFloat(data[0].lon);
                        document.getElementById('latInput').value = lat;
                        document.getElementById('lngInput').value = lng;
                        document.getElementById('locationPreview').innerText = '✓ Found: ' + data[0].display_name;
                        var mapDiv = document.getElementById('mapPreview');
                        mapDiv.style.display = 'block';
                        if (previewMap) {
                            previewMap.setView([lat, lng], 14);
                            previewMarker.setLatLng([lat, lng]);
                        } else {
                            previewMap = L.map('mapPreview').setView([lat, lng], 14);
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '© OpenStreetMap'
                            }).addTo(previewMap);
                            previewMarker = L.marker([lat, lng]).addTo(previewMap);
                        }
                    } else {
                        document.getElementById('locationPreview').innerText = 'Location not found. Try a different postcode or address.';
                    }
                });
        }