extends layout
block content
    .hero
        h1 Welcome to CommunityShare
        p Share more. Waste less. Connect local.
        .hero-buttons
            if session && session.loggedIn
                a.btn-white(href='/listings') Browse Listings
                a.btn-outline(href='/listings/new') Post a Listing
            else
                a.btn-white(href='/login') Login
                a.btn-outline(href='/register') Register

    if session && session.loggedIn && recommendations && recommendations.length > 0
        h2.page-title Recommended for You
        .cards-grid
            each item in recommendations
                .card
                    if item.imageURL
                        img(src=item.imageURL alt=item.title)
                    else
                        .no-image No Image
                    .card-body
                        h3
                            a(href='/listings/' + item.listingID) #{item.title}
                        span.category-badge #{item.category}
                        if item.avgRating
                            span.rating-badge #{parseFloat(item.avgRating).toFixed(1)} ★
                        .card-meta Posted by #{item.username}